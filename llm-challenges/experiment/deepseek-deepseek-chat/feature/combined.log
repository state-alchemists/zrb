     import json
     from fastapi.testclient import TestClient
     from app.main import app
     from app.models import Task, TaskStatus
     from app.database import tasks
     
     client = TestClient(app)
     
     def reset():
         tasks.clear()
         tasks.append(Task(id=1, title="Design schema", status=TaskStatus.done, priority=5, project_id=1, assigned_to="alice"))
         tasks.append(Task(id=2, title="Implement API", status=TaskStatus.in_progress, priority=4, project_id=1, assigned_to="bob"))
         tasks.append(Task(id=3, title="Write tests", status=TaskStatus.todo, priority=3, project_id=1))
         tasks.append(Task(id=4, title="Deploy to staging", status=TaskStatus.todo, priority=2, project_id=2, assigned_to="alice"))
     
     reset()
     
     # === 1. Auth - no key ===
     r = client.post("/tasks", json={"title":"x","project_id":1})

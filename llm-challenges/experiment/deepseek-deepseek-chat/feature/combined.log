     import uvicorn, httpx, threading, time
     from app.main import app
     
     BASE = 'http://127.0.0.1:8000'
     HEADERS = {'X-API-Key': 'dev-key-alice'}
     
     def test(desc, method, path, **kwargs):
         fn = getattr(httpx, method)
         r = fn(f'{BASE}{path}', **kwargs)
         return r
     
     passed = 0
     
     def check(desc, condition):
         global passed
         if condition:
             passed += 1
             print(f'  PASS: {desc}')
         else:
             print(f'  FAIL: {desc}')
     
     def smoke():
         time.sleep(2)
         global passed
     
         r = test('GET /projects', 'get', '/projects')
         check('list projects', r.status_code == 200 and len(r.json()) == 2)
     
         r = test('GET /tasks (unfiltered)', 'get', '/tasks')
         check('unfiltered returns 4', r.status_code == 200 and len(r.json()) == 4)
     
         r = test('GET /tasks (status=todo)', 'get', '/tasks', params={'status': 'todo'})
         check('filter by status', r.status_code == 200 and len(r.json()) == 2)
     
         r = test('GET /tasks (status=todo, assigned_to=alice)', 'get', '/tasks', params={'status': 'todo', 'assigned_to': 'alice'})
         check('filter by status+assigned_to', r.status_code == 200 and len(r.json()) == 1 and r.json()[0]['id'] == 4)
     
         r = test('GET /tasks (priority=5)', 'get', '/tasks', params={'priority': 5})
         check('filter by priority=5', r.status_code == 200 and len(r.json()) == 1 and r.json()[0]['id'] == 1)
     
         r = test('GET /tasks (page=1, page_size=2)', 'get', '/tasks', params={'page': 1, 'page_size': 2})
         check('pagination page 1', r.status_code == 200 and len(r.json()) == 2)
     
         r = test('GET /tasks (page=3, page_size=2)', 'get', '/tasks', params={'page': 3, 'page_size': 2})
         check('pagination empty page', r.status_code == 200 and len(r.json()) == 0)
     
         r = test('GET /tasks/1', 'get', '/tasks/1')
         check('get single task', r.status_code == 200 and r.json()['title'] == 'Design schema')
     
         r = test('GET /tasks/999', 'get', '/tasks/999')
         check('get nonexistent task', r.status_code == 404)
     
         # Now test auth-gated endpoints
     
         r = test('POST /tasks (no auth)', 'post', '/tasks', json={'title': 'New', 'project_id': 1})
         check('create without auth -> 401', r.status_code == 401)
     
         r = test('POST /tasks (bad project_id)', 'post', '/tasks', json={'title': 'New', 'project_id': 99}, headers=HEADERS)
         check('create with invalid project -> 404', r.status_code == 404)
     
         r = test('POST /tasks (valid)', 'post', '/tasks', json={'title': 'New task', 'project_id': 2, 'priority': 1}, headers=HEADERS)
         check('create task', r.status_code == 201)
         if r.status_code == 201:
             c = r.json()
             check('  id=5', c['id'] == 5)
             check('  title=New task', c['title'] == 'New task')
             check('  project_id=2', c['project_id'] == 2)
             check('  assigned_to is None', c['assigned_to'] is None)
     
         r = test('PUT /tasks/999 (not found)', 'put', '/tasks/999', json={'title': 'nope'}, headers=HEADERS)
         check('update nonexistent -> 404', r.status_code == 404)
     
         r = test('PUT /tasks/1 (partial update)', 'put', '/tasks/1', json={'title': 'Updated title', 'priority': 10}, headers=HEADERS)
         check('update task', r.status_code == 200)
         if r.status_code == 200:
             u = r.json()
             check('  title updated', u['title'] == 'Updated title')
             check('  priority updated', u['priority'] == 10)
             check('  status unchanged', u['status'] == 'done')
     
         r = test('DELETE /tasks/5', 'delete', '/tasks/5', headers=HEADERS)
         check('delete task', r.status_code == 204)
     
         r = test('DELETE /tasks/5 again', 'delete', '/tasks/5', headers=HEADERS)
         check('delete gone -> 404', r.status_code == 404)
     
         r = test('DELETE /tasks/1 (no auth)', 'delete', '/tasks/1')
         check('delete without auth -> 401', r.status_code == 401)
     
         r = test('PUT /tasks/1 (no auth)', 'put', '/tasks/1', json={'title': 'x'})
         check('update without auth -> 401', r.status_code == 401)
     
         r = test('POST /tasks (bad key)', 'post', '/tasks', json={'title': 'x', 'project_id': 1}, headers={'X-API-Key': 'bad-key'})

     from app.main import app
     
     # Test list_tasks with filters and pagination
     from fastapi.testclient import TestClient
     client = TestClient(app)
     
     # 1. No auth on public endpoints
     r = client.get('/tasks')
     print('GET /tasks (no auth):', r.status_code, len(r.json()))
     
     # 2. Filter by status
     r = client.get('/tasks?status=todo')
     print('GET /tasks?status=todo:', r.status_code, len(r.json()))
     assert all(t['status'] == 'todo' for t in r.json())
     
     # 3. Pagination
     r = client.get('/tasks?page=1&page_size=2')
     print('GET /tasks?page=1&page_size=2:', r.status_code, len(r.json()))
     assert len(r.json()) == 2
     
     r = client.get('/tasks?page=3&page_size=2')
     print('GET /tasks?page=3&page_size=2:', r.status_code, len(r.json()))
     assert len(r.json()) == 0
     
     # 4. POST without auth -> 401
     r = client.post('/tasks', json={'title': 'test', 'project_id': 1})
     print('POST /tasks (no auth):', r.status_code)
     assert r.status_code == 401
     
     # 5. POST with bad key -> 401
     r = client.post('/tasks', json={'title': 'test', 'project_id': 1}, headers={'X-API-Key': 'bad-key'})
     print('POST /tasks (bad key):', r.status_code)
     assert r.status_code == 401
     

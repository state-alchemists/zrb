     assert r.status_code == 404
     print("4. Create - missing project: PASS")
     
     # === 5. List - no filters ===
     r = client.get("/tasks")
     data = r.json()
     assert len(data) == 5
     print("5. List - no filters: PASS")
     
     # === 6. List - filter by status ===
     r = client.get("/tasks?status=todo")
     data = r.json()
     assert all(t["status"] == "todo" for t in data)
     assert len(data) == 3  # task 3, 4, 5
     print("6. List - filter by status: PASS")
     
     # === 7. List - filter by priority ===
     r = client.get("/tasks?priority=3")
     data = r.json()
     assert all(t["priority"] == 3 for t in data)
     assert len(data) == 1
     print("7. List - filter by priority: PASS")
     
     # === 8. List - filter by assigned_to ===
     r = client.get("/tasks?assigned_to=alice")
     data = r.json()
     assert all(t["assigned_to"] == "alice" for t in data)
     assert len(data) == 2
     print("8. List - filter by assigned_to: PASS")
     
     # === 9. List - combined filters ===
     r = client.get("/tasks?status=todo&assigned_to=alice")
     data = r.json()
     assert len(data) == 1  # only task 4
     print("9. List - combined filters: PASS")
     
     # === 10. Pagination - page 1, page_size 2 ===
     r = client.get("/tasks?page=1&page_size=2")
     data = r.json()
     assert len(data) == 2
     assert data[0]["id"] == 1
     assert data[1]["id"] == 2
     print("10. Pagination - page 1, page_size 2: PASS")
     
     # === 11. Pagination - page 3, page_size 2 ===
     r = client.get("/tasks?page=3&page_size=2")
     data = r.json()
     assert len(data) == 1
     assert data[0]["id"] == 5
     print("11. Pagination - page 3, page_size 2: PASS")
     

     print("1. Auth - no key: PASS")
     
     # === 2. Auth - bad key ===
     r = client.post("/tasks", json={"title":"x","project_id":1}, headers={"X-API-Key":"bad-key"})
     assert r.status_code == 401
     print("2. Auth - bad key: PASS")
     
     # === 3. Create task ===
     r = client.post("/tasks", json={"title":"New task","project_id":1}, headers={"X-API-Key":"dev-key-alice"})
     assert r.status_code == 200, f"Got {r.status_code}: {r.text}"
     data = r.json()
     assert data["title"] == "New task"
     assert data["id"] == 5
     assert data["assigned_to"] is None
     print("3. Create task: PASS")
     
     # === 4. Create - missing project ===

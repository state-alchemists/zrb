     resp = client.post('/tasks', json={'title': 'Test', 'project_id': 1})
     assert resp.status_code == 401, 'Should require key'
     resp = client.post('/tasks', json={'title': 'Test', 'project_id': 999}, headers={'X-API-Key': 'dev-key-alice'})
     assert resp.status_code == 404, 'Should validate project exists (project_id=999 does not exist)'
     print('✓ Authentication tests passed')
     
     # Test 2: Filtering works

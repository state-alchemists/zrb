  🔠 call_00_nI2iIsxevvwcTUgJVeIs5606 | Return Command: for i in $(seq 1 10); do python -c "
     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     from checkout import checkout
     
     async def stress():
         inv = Inventory(50)
         gw = PaymentGateway(failure_rate=0.3)
         orders = [checkout(f'order_{i}', 1, 100.0, inv, gw) for i in range(200)]
         results = await asyncio.gather(*orders)
         errs = []
         if inv.stock < 0: errs.append('negative stock')
         if abs(gw.total_charged - sum(results) * 100.0) > 0.01: errs.append('charge mismatch')
         charge_ids = [c['order_id'] for c in gw.charges]
         if len(charge_ids) != len(set(charge_ids)): errs.append('duplicates')
         if errs:
             print(f'FAIL: {errs}')
         else:
             print(f'OK: {sum(results)}/200 ok, stock={inv.stock}, charged=\${gw.total_charged}')
     
     asyncio.run(stress())
     " 2>&1; done

     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     from checkout import checkout
     
     async def test_extreme():
         # Test with more concurrent orders than stock
         inventory = Inventory(3)
         gateway = PaymentGateway(failure_rate=0.3)  # Higher failure rate
         
         print('Extreme test: 10 concurrent orders, stock=3, high failure rate')
         orders = [
             checkout(f'order_{i}', 1, 100.0, inventory, gateway)
             for i in range(10)
         ]

         95	            yield UserActivity(timestamp=entry.timestamp, user_id=user_match.group("user_id"))
         96	
         97	
         98	def load_records(records: Iterable[ExtractedRecord], settings: Settings) -> None:
         99	    print(f"Connecting to {settings.db_host} as {settings.db_user}...")
        100	    _ = settings.db_password
        101	    for _record in records:
        102	        pass
        103	
        104	
        105	def summarize_errors(records: Iterable[ExtractedRecord]) -> Counter[str]:
        106	    return Counter(
        107	        record.message
        108	        for record in records
        109	        if isinstance(record, LogEntry) and record.level == "ERROR"
        110	    )
        111	
        112	
        113	def render_report(error_summary: Counter[str]) -> str:
        114	    lines = [
        115	        "<html>",
        116	        "<head><title>System Report</title></head>",
        117	        "<body>",
        118	        "<h1>Error Summary</h1>",
        119	        "<ul>",
        120	    ]
        121	    for err_msg, count in error_summary.items():
        122	        safe_message = html.escape(err_msg)
        123	        lines.append(f"<li><b>{safe_message}</b>: {count} occurrences</li>")
        124	    lines.extend(["</ul>", "</body>", "</html>"])
        125	    return "\n".join(lines)
        126	
        127	
        128	def write_report(report_file: Path, report_html: str) -> None:
        129	    report_file.write_text(report_html, encoding="utf-8")
        130	
        131	
        132	def run() -> None:
        133	    settings = Settings.from_env()
        134	    ensure_sample_log(settings.log_file)
        135	    records = extract_records(settings.log_file)
        136	    load_records(records, settings)
        137	    error_summary = summarize_errors(records)
        138	    write_report(settings.report_file, render_report(error_summary))
        139	    print(f"Job finished at {dt.datetime.now()}")
        140	
        141	
        142	if __name__ == "__main__":
        143	    run()
     
     --- README ---
          1	# ETL Log Report
          2	
          3	This project reads an application log, extracts structured events, simulates loading them to a database, and writes `report.html` with the same report format used before.
          4	
          5	## Configuration
          6	
          7	The script now reads configuration from environment variables instead of hardcoded values:
          8	
          9	- `ETL_DB_HOST` (default: `localhost`)
         10	- `ETL_DB_USER` (default: `admin`)
         11	- `ETL_DB_PASSWORD` (default: `password123`)
         12	- `ETL_LOG_FILE` (default: `server.log`)
         13	- `ETL_REPORT_FILE` (default: `report.html`)
         14	
         15	## Usage
         16	
         17	```bash
         18	python3 etl.py
         19	```
         20	
         21	Example with custom configuration:
         22	
         23	```bash
         24	ETL_DB_HOST=db.internal \
         25	ETL_DB_USER=reporter \
         26	ETL_DB_PASSWORD=secret \
         27	python3 etl.py
         28	```
         29	
         30	## Notes
         31	
         32	- Parsing is whitespace-tolerant for supported log lines.
         33	- The generated `report.html` structure is preserved.
         34	- A sample log file is created automatically if the configured log file does not exist.
         35	
         36	## Tests
         37	
         38	```bash
         39	pytest -q
         40	```
     

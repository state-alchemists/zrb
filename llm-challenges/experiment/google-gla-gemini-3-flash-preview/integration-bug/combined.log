Expected charge:    $500.00
Duplicate charges:  0
```

#### `inventory.py`
```python
import asyncio

class Inventory:
    def __init__(self, stock: int):
        self._stock = stock
        self._lock = asyncio.Lock()

    async def decrement(self, quantity: int) -> bool:
        async with self._lock:
            await asyncio.sleep(0.02)
            if self._stock >= quantity:
                self._stock -= quantity
                return True
            return False

    async def increment(self, quantity: int) -> None:
        async with self._lock:
            await asyncio.sleep(0.01)
            self._stock += quantity
    # ...
```

#### `checkout.py`
```python
async def checkout(...):
    # Reserve inventory first
    if not await inventory.decrement(quantity):
        return False

    # Attempt payment
    if not await gateway.charge(order_id, quantity * price):
        await inventory.increment(quantity) # Refund inventory on failure
        return False

    return True
```

     from fastapi.testclient import TestClient
     from app.main import app
     from app.database import tasks, projects
     
     client = TestClient(app)
     
     def test_auth():
         # missing auth
         response = client.post("/tasks", json={"title": "Test", "project_id": 1})
         assert response.status_code == 401
         
         # invalid auth
         response = client.post("/tasks", headers={"X-API-Key": "invalid"}, json={"title": "Test", "project_id": 1})
         assert response.status_code == 401
         
         # valid auth
         response = client.post("/tasks", headers={"X-API-Key": "dev-key-alice"}, json={"title": "Test", "project_id": 1})
         assert response.status_code == 200
     
     def test_filtering_and_pagination():
         response = client.get("/tasks")
         assert response.status_code == 200
         assert len(response.json()) > 0
         
         # filter by status
         response = client.get("/tasks?status=done")
         assert response.status_code == 200
         assert all(t['status'] == 'done' for t in response.json())
         
         # pagination
         response = client.get("/tasks?page=1&page_size=2")
         assert response.status_code == 200
         assert len(response.json()) == 2
     
     def test_update():
         response = client.put("/tasks/1", headers={"X-API-Key": "dev-key-alice"}, json={"title": "Updated Title"})
         assert response.status_code == 200
         assert response.json()["title"] == "Updated Title"
     
     def test_delete():
         response = client.delete("/tasks/1", headers={"X-API-Key": "dev-key-alice"})
         assert response.status_code == 200
         response = client.get("/tasks/1")
         assert response.status_code == 404
     
     if __name__ == "__main__":
         test_auth()
         test_filtering_and_pagination()
         test_update()
         test_delete()
         print("All tests passed.")
     EOF

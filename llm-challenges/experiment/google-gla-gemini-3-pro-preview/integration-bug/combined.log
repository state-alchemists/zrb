     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     
     _processing = set()
     _completed = set()
     
     async def checkout(
         order_id: str,
         quantity: int,
         price: float,
         inventory: Inventory,
         gateway: PaymentGateway,
     ) -> bool:
         if order_id in _completed or order_id in _processing:
             return False
             
         _processing.add(order_id)
         try:
             # Reserve stock
             decremented = await inventory.decrement(quantity)
             if not decremented:
                 print(f"Order {order_id}: out of stock")
                 return False
     
             # Charge payment
             charged = await gateway.charge(order_id, quantity * price)
             if not charged:
                 print(f"Order {order_id}: payment failed, refunding stock")
                 await inventory.increment(quantity)
                 return False
     
             print(f"Order {order_id}: SUCCESS")
             _completed.add(order_id)
             return True
         finally:
             _processing.remove(order_id)

     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     
     _processed_orders = set()
     _order_locks = {}
     _global_lock = asyncio.Lock()
     
     async def get_order_lock(order_id: str) -> asyncio.Lock:
         async with _global_lock:
             if order_id not in _order_locks:
                 _order_locks[order_id] = asyncio.Lock()
             return _order_locks[order_id]
     
     async def checkout(
         order_id: str,
         quantity: int,
         price: float,
         inventory: Inventory,
         gateway: PaymentGateway,
     ) -> bool:
         lock = await get_order_lock(order_id)
         
         async with lock:
             # If already successfully processed, don't charge again.
             if order_id in _processed_orders:
                 print(f"Order {order_id}: already processed")
                 return True  # Or False, but the point is we don't charge again.
                 
             # 1. Reserve inventory
             decremented = await inventory.decrement(quantity)
             if not decremented:
                 print(f"Order {order_id}: out of stock")
                 return False
     
             # 2. Process payment
             try:
                 charged = await gateway.charge(order_id, quantity * price)
             except Exception as e:
                 print(f"Order {order_id}: payment error - {e}")
                 charged = False
     
             if not charged:
                 print(f"Order {order_id}: payment failed")
                 # 3. Rollback inventory if payment fails
                 await inventory.increment(quantity)
                 return False
     
             # Mark as successfully processed
             _processed_orders.add(order_id)
             print(f"Order {order_id}: SUCCESS")
             return True
     EOF

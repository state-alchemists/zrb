     class Inventory:
         def __init__(self, stock: int):
             self._stock = stock
     
         async def check_stock(self, quantity: int) -> bool:
             await asyncio.sleep(0.02)
             return self._stock >= quantity
     
         async def decrement(self, quantity: int) -> bool:
             await asyncio.sleep(0.02)
             if self._stock >= quantity:

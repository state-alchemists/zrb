     from fastapi.testclient import TestClient
     from app.main import app, tasks, projects
     import copy
     
     # Reset state to known values
     original_tasks = copy.deepcopy(tasks)
     original_projects = copy.deepcopy(projects)
     
     tasks[:] = original_tasks
     projects[:] = original_projects
     
     client = TestClient(app)
     
     # 1. Auth: missing key
     r = client.post('/tasks', json={'title': 'x', 'project_id': 1})
     assert r.status_code == 401, f'Expected 401, got {r.status_code}'
     
     # 2. Auth: invalid key
     r = client.post('/tasks', json={'title': 'x', 'project_id': 1}, headers={'X-API-Key': 'bad'})
     assert r.status_code == 401, f'Expected 401, got {r.status_code}'
     
     # 3. Create task: valid auth, invalid project
     r = client.post('/tasks', json={'title': 'x', 'project_id': 99}, headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 404, f'Expected 404, got {r.status_code}'
     
     # 4. Create task: valid auth, valid project
     r = client.post('/tasks', json={'title': 'New Task', 'project_id': 1, 'priority': 2}, headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 201, f'Expected 201, got {r.status_code}'
     data = r.json()
     assert data['title'] == 'New Task'
     assert data['id'] == 5
     new_task_id = data['id']
     
     # 5. List tasks with filter
     r = client.get('/tasks?status=todo&assigned_to=alice')
     assert r.status_code == 200
     data = r.json()
     assert all(t['status'] == 'todo' and t.get('assigned_to') == 'alice' for t in data)
     
     # 6. Pagination
     r = client.get('/tasks?page=1&page_size=2')
     assert r.status_code == 200
     data = r.json()
     assert len(data) == 2
     
     # 7. Update task
     r = client.put(f'/tasks/{new_task_id}', json={'title': 'Updated Task', 'status': 'done'}, headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 200
     data = r.json()
     assert data['title'] == 'Updated Task'
     assert data['status'] == 'done'
     assert data['priority'] == 2  # unchanged
     
     # 8. Update missing task
     r = client.put('/tasks/999', json={'title': 'x'}, headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 404
     
     # 9. Delete task
     r = client.delete(f'/tasks/{new_task_id}', headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 204
     
     # 10. Delete missing task
     r = client.delete('/tasks/999', headers={'X-API-Key': 'dev-key-alice'})
     assert r.status_code == 404
     
     # Reset state
     tasks[:] = original_tasks
     projects[:] = original_projects
     
     print('All tests passed!')
     "

     from pydantic import BaseModel
     from typing import Optional
     from enum import Enum
     
     
     class TaskStatus(str, Enum):
         todo = "todo"
         in_progress = "in_progress"
         done = "done"
     
     
     class Task(BaseModel):
         id: int
         title: str
         status: TaskStatus = TaskStatus.todo
         priority: int = 3
         project_id: int

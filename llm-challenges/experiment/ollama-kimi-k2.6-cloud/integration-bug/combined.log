         charged =[0m[2m await gateway[0m[2m.charge[0m[2m(order_id[0m[2m, quantity[0m[2m * price[0m[2m)[0m[2m
         if not[0m[2m charged:[0m[2m
             #[0m[2m rollback[0m[2m reservation[0m[2m
             await inventory[0m[2m.increment([0m[2mquantity)[0m[2m

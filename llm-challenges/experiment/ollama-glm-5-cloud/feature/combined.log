         priority: int = 3
         project_id: int
         assigned_to: Optional[str] = None
     
     
     class TaskUpdate(BaseModel):
         title: Optional[str] = None
         status: Optional[TaskStatus] = None
         priority: Optional[int] = None
         assigned_to: Optional[str] = None
     
     
     class Project(BaseModel):
         id: int
         name: str

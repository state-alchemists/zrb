                             uid = parsed_line["u"]
                             action = parsed_line["a"]
                             if "logged in" in action:
                                 sessions[uid] = parsed_line["d"]
                             elif "logged out" in action and uid in sessions:
                                 sessions.pop(uid)
                             d_list.append(parsed_line)
                         elif "endpoint" in parsed_line: # API call

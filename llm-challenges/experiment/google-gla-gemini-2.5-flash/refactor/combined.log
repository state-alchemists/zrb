         # 2024-01-01 12:08:00 INFO API /users/profile took 250ms
         # 2024-01-01 12:09:00 WARN Memory usage at 87%
     
         log_pattern = re.compile(
             r"^(?P<date>\d{4}-\d{2}-\d{2})\s(?P<time>\d{2}:\d{2}:\d{2})\s"
             r"(?P<level>[A-Z]+)\s(?P<message>.*)$"

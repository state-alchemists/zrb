                 if api_match:
                     api_data = api_match.groupdict()
                     duration = int(api_data['ms']) if api_data['ms'] else 0
                     return {"d": timestamp, "t": "API", "endpoint": api_data['endpoint'], "ms": duration}
         elif level == "WARN":
             return {"d": timestamp, "t": "WARN", "m": message.strip()}
     
         return None
     

         out += "<h2>Active Sessions</h2>\n"
         out += "<p>" + str(len(sessions)) + " user(s) currently active</p>\n"
         out += "</body>\n</html>"
     
         with open("report.html", "w") as f:
             f.write(out)
     
         print("Job finished at " + str(datetime.datetime.now()))
     
     
     if __name__ == "__main__":

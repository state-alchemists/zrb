     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     from checkout import checkout
     
     ITEM_PRICE = 100.0
     INITIAL_STOCK = 2
     NUM_ORDERS = 10
     
     async def main():
         for run in range(50):
             inventory = Inventory(INITIAL_STOCK)
             gateway = PaymentGateway(failure_rate=0.0)  # No random failures
             
             orders = [
                 checkout(f"order_{i}", 1, ITEM_PRICE, inventory, gateway)
                 for i in range(NUM_ORDERS)
             ]
             await asyncio.gather(*orders)
             
             remaining = inventory.stock
             if remaining < 0:
                 print(f"RUN {run}: NEGATIVE INVENTORY - remaining={remaining}")
                 break
         else:
             print("No negative inventory seen in 50 runs")
     
     asyncio.run(main())
     EOF

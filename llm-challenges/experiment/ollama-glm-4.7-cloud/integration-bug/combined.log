     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     from checkout import checkout
     
     async def test_duplicate_charge():
         '''Test that the same order_id cannot be charged twice'''
         inventory = Inventory(10)
         gateway = PaymentGateway(failure_rate=0.0)  # No failures
         
         # Try to checkout the same order twice
         result1 = await checkout('order_dup', 1, 100.0, inventory, gateway)
         result2 = await checkout('order_dup', 1, 100.0, inventory, gateway)
         
         print(f'First checkout: {result1}')
         print(f'Second checkout (same order_id): {result2}')
         print(f'Total charges: {len(gateway.charges)}')
         print(f'Expected: 1 charge, first succeeds, second is skipped')
         assert result1 == True, 'First checkout should succeed'
         assert result2 == False, 'Second checkout should fail (already charged)'
         assert len(gateway.charges) == 1, 'Should have exactly 1 charge'
         print('✓ Duplicate charge prevention works')
     
     asyncio.run(test_duplicate_charge())

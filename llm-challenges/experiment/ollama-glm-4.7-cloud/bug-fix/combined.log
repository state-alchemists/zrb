         queue.enqueue({"name": "bad_task_1", "raise_error": True})
         queue.enqueue({"name": "bad_task_2", "raise_error": True})
     
         workers = [process_job(queue, i) for i in range(5)]
         await asyncio.gather(*workers)
     

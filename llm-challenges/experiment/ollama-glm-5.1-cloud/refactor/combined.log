             avg = sum(times) / len(times)
             out += "<tr><td>" + ep + "</td><td>" + str(round(avg, 1)) + "</td></tr>\n"
         out += "</table>\n"
     
         out += "<h2>Active Sessions</h2>\n"
         out += "<p>" + str(len(sessions)) + " user(s) currently active</p>\n"
         out += "</body>\n</html>"
     

     from fastapi.testclient import TestClient
     from app.main import app
     
     client = TestClient(app)
     
     # 1. Auth: missing key → 401
     r = client.post('/tasks', json={'title':'X','project_id':1})
     assert r.status_code == 401, f'expected 401 got {r.status_code}'
     
     # 1. Auth: invalid key → 401
     r = client.post('/tasks', json={'title':'X','project_id':1}, headers={'X-API-Key':'bad-key'})
     assert r.status_code == 401, f'expected 401 got {r.status_code}'
     
     # 1. Auth: valid key → accepted
     r = client.post('/tasks', json={'title':'Valid','project_id':1}, headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 201, f'expected 201 got {r.status_code} {r.json()}'
     
     # 2. Filtering: by status
     r = client.get('/tasks', params={'status':'todo'})
     assert all(t['status']=='todo' for t in r.json()), 'status filter failed'
     
     # 2. Filtering: by priority
     r = client.get('/tasks', params={'priority':5})
     assert all(t['priority']==5 for t in r.json()), 'priority filter failed'
     
     # 2. Filtering: by assigned_to
     r = client.get('/tasks', params={'assigned_to':'alice'})
     assert all(t['assigned_to']=='alice' for t in r.json()), 'assigned_to filter failed'
     
     # 2. Filtering: combined
     r = client.get('/tasks', params={'status':'todo','assigned_to':'alice'})
     data = r.json()
     assert len(data) > 0, 'combined filter empty'
     assert all(t['status']=='todo' and t['assigned_to']=='alice' for t in data), 'combined filter failed'
     
     # 3. Pagination
     r = client.get('/tasks', params={'page':1,'page_size':2})
     assert len(r.json()) == 2, f'page_size=2 should return 2, got {len(r.json())}'
     
     r = client.get('/tasks', params={'page':99,'page_size':2})
     assert r.json() == [], 'out-of-range page should return []'
     
     # 4. Create task with invalid project → 404
     r = client.post('/tasks', json={'title':'X','project_id':999}, headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 404, f'expected 404 got {r.status_code}'
     
     # 4. Create task — auto-generated ID
     r = client.post('/tasks', json={'title':'New','project_id':2,'priority':1}, headers={'X-API-Key':'dev-key-bob'})
     assert r.status_code == 201
     task = r.json()
     assert task['id'] > 4, f'auto-id should be >4, got {task[\"id\"]}'
     assert task['title'] == 'New'
     
     # 5. Update task
     task_id = task['id']
     r = client.put(f'/tasks/{task_id}', json={'title':'Updated','status':'done'}, headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 200
     assert r.json()['title'] == 'Updated'
     assert r.json()['status'] == 'done'
     
     # 5. Update non-existent task → 404
     r = client.put('/tasks/9999', json={'title':'X'}, headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 404
     
     # 6. Delete task
     r = client.delete(f'/tasks/{task_id}', headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 204
     
     # 6. Delete same again → 404
     r = client.delete(f'/tasks/{task_id}', headers={'X-API-Key':'dev-key-alice'})
     assert r.status_code == 404
     
     print('ALL TESTS PASSED')

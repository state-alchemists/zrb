         async def charge(self, order_id: str, amount: float) -> bool:
             await asyncio.sleep(0.03)
             if random.random() < self._failure_rate:
                 return False
             self.total_charged += amount
             self.charges.append({"order_id": order_id, "amount": amount})
             return True
     

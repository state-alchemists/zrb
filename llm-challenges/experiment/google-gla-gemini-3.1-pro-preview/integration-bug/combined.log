     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     
     _order_locks = set()
     
     async def checkout(
         order_id: str,
         quantity: int,
         price: float,
         inventory: Inventory,
         gateway: PaymentGateway,
     ) -> bool:
         # Idempotency check: if order was already charged, return True
         for charge in gateway.charges:
             if charge["order_id"] == order_id:
                 return True
     
         # Prevent concurrent processing of the same order
         if order_id in _order_locks:
             return False
     
         _order_locks.add(order_id)
         try:
             # 1. Reserve stock first
             decremented = await inventory.decrement(quantity)
             if not decremented:
                 print(f"Order {order_id}: out of stock")
                 return False
     
             # 2. Charge the payment
             charged = await gateway.charge(order_id, quantity * price)
             if not charged:
                 # 3. Rollback stock if payment fails
                 await inventory.increment(quantity)
                 print(f"Order {order_id}: payment failed")
                 return False
     
             print(f"Order {order_id}: SUCCESS")
             return True
         finally:
             _order_locks.remove(order_id)

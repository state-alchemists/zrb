     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     
     async def checkout(
         order_id: str,
         quantity: int,
         price: float,
         inventory: Inventory,
         gateway: PaymentGateway,
     ) -> bool:
         # Idempotency check: if already charged, do not charge again
         for c in gateway.charges:
             if c["order_id"] == order_id:
                 return True
     
         decremented = await inventory.decrement(quantity)
         if not decremented:
             print(f"Order {order_id}: out of stock")

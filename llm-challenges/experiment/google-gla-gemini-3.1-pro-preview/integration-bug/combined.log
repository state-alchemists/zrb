     import asyncio
     from inventory import Inventory
     from payments import PaymentGateway
     
     # Track ongoing or completed orders to ensure idempotency and prevent duplicates
     _processed_orders = set()
     _order_locks = set()
     
     async def checkout(
         order_id: str,
         quantity: int,
         price: float,
         inventory: Inventory,
         gateway: PaymentGateway,
     ) -> bool:
         if order_id in _processed_orders:
             return True
             
         # Naive locking for the same order_id
         if order_id in _order_locks:
             # Wait until the lock is released
             while order_id in _order_locks:
                 await asyncio.sleep(0.01)
             # Check if it was processed
             return order_id in _processed_orders
             
         _order_locks.add(order_id)
         try:
             decremented = await inventory.decrement(quantity)
             if not decremented:
                 return False
     
             charged = await gateway.charge(order_id, quantity * price)
             if not charged:
                 await inventory.increment(quantity)
                 return False
     
             _processed_orders.add(order_id)
             return True
         finally:
             _order_locks.remove(order_id)
     EOF

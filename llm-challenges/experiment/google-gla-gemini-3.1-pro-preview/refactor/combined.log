                         dur = line.split("took ")[1].split("ms")[0] if "took" in line else "0"
                         api_calls.append({"d": dt, "endpoint": endpoint, "ms": int(dur)})
     
                     elif lvl == "WARN":
                         m = " ".join(s[3:]).strip()
                         d_list.append({"d": dt, "t": "WARN", "m": m})
             f.close()
     
